{
  "name": "hamusrang-discord-bot",
  "version": "0.0.2",
  "description": "함수랑 산악회 디스코드 내에서 사용하는 discord bot 입니다. ",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch --include \"./src/**\" --env-file=.local.env src/index.ts",
    "deploy": "tsx src/deploy-commands.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "dependencies": {
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "@snazzah/davey": "^0.1.10",
    "better-sqlite3": "^12.8.0",
    "discord.js": "^14.25.1",
    "ffmpeg-static": "^5.3.0",
    "node-cron": "^4.2.1",
    "node-html-parser": "^7.1.0",
    "openai": "^6.27.0",
    "sodium-native": "^5.1.0",
    "youtube-transcript": "^1.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.15",
    "@types/node-cron": "^3.0.11",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
